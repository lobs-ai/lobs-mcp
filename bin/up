#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

# Load defaults (repo .env, user config, etc.)
# shellcheck disable=SC1091
source "$ROOT_DIR/bin/_env.sh"

SOCKET_PATH="$LOBS_BRIDGE_SOCKET"

ms_now() {
  date +%s%3N 2>/dev/null || python3 - <<'PY'
import time
print(int(time.time()*1000))
PY
}

wait_for_socket() {
  local sock="$1"
  local timeout_ms="${2:-5000}"
  local start
  start=$(ms_now)
  while true; do
    if [ -S "$sock" ]; then
      return 0
    fi
    local now
    now=$(ms_now)
    if (( now - start >= timeout_ms )); then
      return 1
    fi
    sleep 0.1
  done
}

ensure_deps() {
  if [ ! -x "node_modules/.bin/tsc" ]; then
    echo "[lobs-up] Installing dependencies..." >&2
    npm install >&2
  fi
}

start_bridge_bg() {
  if [ -S "$SOCKET_PATH" ]; then
    echo "[lobs-up] Bridge socket already present: $SOCKET_PATH" >&2
    return 0
  fi

  # Remove stale socket (created by a crashed/killed daemon)
  rm -f "$SOCKET_PATH" 2>/dev/null || true

  echo "[lobs-up] Starting bridge (gcal-bridge) detached..." >&2
  mkdir -p "$ROOT_DIR/.run"

  # Prefer systemd user service if available: survives parent SIGKILL and gives clean logs.
  if command -v systemctl >/dev/null 2>&1; then
    if systemctl --user start gcal-bridge >/dev/null 2>&1; then
      echo "[lobs-up] Started bridge via: systemctl --user start gcal-bridge" >&2
      return 0
    fi
  fi

  # Fallback: hard detach using setsid so the bridge survives when the caller gets SIGKILL.
  if command -v setsid >/dev/null 2>&1; then
    setsid -f env \
      LOBS_BRIDGE_LOG_LEVEL="${LOBS_BRIDGE_LOG_LEVEL:-debug}" \
      LOBS_BRIDGE_SOCKET_MODE="${LOBS_BRIDGE_SOCKET_MODE:-0666}" \
      "$ROOT_DIR/bin/start-bridge" \
      >>"$ROOT_DIR/.run/gcal-bridge.log" 2>&1
    return 0
  fi

  # Last resort.
  nohup env \
    LOBS_BRIDGE_LOG_LEVEL="${LOBS_BRIDGE_LOG_LEVEL:-debug}" \
    LOBS_BRIDGE_SOCKET_MODE="${LOBS_BRIDGE_SOCKET_MODE:-0666}" \
    "$ROOT_DIR/bin/start-bridge" \
    >>"$ROOT_DIR/.run/gcal-bridge.log" 2>&1 < /dev/null &
}

ensure_deps

# Bridge first (creates the socket)
start_bridge_bg

if ! wait_for_socket "$SOCKET_PATH" 5000; then
  echo "[lobs-up] ERROR: bridge socket did not appear: $SOCKET_PATH" >&2
  echo "[lobs-up] Tail logs: tail -n 200 $ROOT_DIR/.run/gcal-bridge.log" >&2
  exit 1
fi

echo "[lobs-up] Bridge ready: $SOCKET_PATH" >&2

# By default, bin/up only ensures the bridge is alive + the socket is ready.
# MCP servers are usually spawned by the MCP client over stdio.
#
# To start MCP manually (foreground), set LOBS_UP_WITH_MCP=1.
if [ "${LOBS_UP_WITH_MCP:-}" != "1" ]; then
  echo "[lobs-up] Bridge is ready at: $SOCKET_PATH" >&2
  exit 0
fi

echo "[lobs-up] Starting MCP server (lobs-mcp) over stdio..." >&2
exec "$ROOT_DIR/bin/start-mcp"
