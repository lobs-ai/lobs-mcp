#!/usr/bin/env bash
set -euo pipefail

# Usage:
#   ./bin/mcp-ping [http://127.0.0.1:17381]
#   ./bin/mcp-ping               # uses LOBS_BRIDGE_HTTP_URL from config/env

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

# Load repo/user config
# shellcheck disable=SC1091
source "$ROOT_DIR/bin/_env.sh"

URL="${1:-${LOBS_BRIDGE_HTTP_URL:-http://127.0.0.1:17381}}"

if ! command -v curl >/dev/null 2>&1; then
  echo "curl is required for mcp-ping" >&2
  exit 1
fi

echo "[mcp-ping] health: $URL/health" >&2
curl -fsS "$URL/health"
echo

echo "[mcp-ping] call: $URL/call (ping)" >&2
curl -fsS "$URL/call" \
  -H 'content-type: application/json' \
  -d '{"id":"ping","method":"ping","params":{}}'
echo
