#!/usr/bin/env bash
set -euo pipefail

# Writes persistent config so you don't need to export env vars.
#
# Usage:
#   ./bin/configure --socket /path/to/bridge.sock [--timeout-ms 15000]

SOCKET=""
TIMEOUT_MS=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --socket)
      SOCKET="$2"; shift 2;;
    --timeout-ms)
      TIMEOUT_MS="$2"; shift 2;;
    -h|--help)
      cat <<'EOF'
Usage:
  ./bin/configure --socket /path/to/bridge.sock [--timeout-ms 15000]

Writes config to:
  ~/.config/lobs-mcp/config.env
EOF
      exit 0;;
    *)
      echo "Unknown arg: $1" >&2
      exit 2;;
  esac
done

if [[ -z "$SOCKET" ]]; then
  echo "Missing --socket" >&2
  exit 2
fi

CONF_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/lobs-mcp"
CONF_FILE="$CONF_DIR/config.env"
mkdir -p "$CONF_DIR"

{
  echo "# lobs-mcp config"
  echo "LOBS_BRIDGE_SOCKET=\"$SOCKET\""
  if [[ -n "$TIMEOUT_MS" ]]; then
    echo "LOBS_BRIDGE_TIMEOUT_MS=\"$TIMEOUT_MS\""
  fi
} > "$CONF_FILE"

chmod 600 "$CONF_FILE"

echo "Wrote $CONF_FILE" >&2
