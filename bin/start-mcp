#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

# Load persistent config (no exports needed beforehand)
# shellcheck disable=SC1091
source "$ROOT_DIR/bin/_env.sh"

# Ensure deps are installed (tsc lives in node_modules/.bin)
if [ ! -x "node_modules/.bin/tsc" ]; then
  echo "[lobs-mcp] Installing dependencies..." >&2
  npm install >&2
fi

# Build then run MCP server over stdio.
# (MCP clients spawn this and communicate via stdin/stdout.)

wait_for_http() {
  local url="$1"
  local timeout_s="${2:-5}"
  local start
  start=$(date +%s)

  while true; do
    if command -v curl >/dev/null 2>&1 && curl -fsS "$url/health" >/dev/null 2>&1; then
      return 0
    fi
    local now
    now=$(date +%s)
    if (( now - start >= timeout_s )); then
      return 1
    fi
    sleep 0.2
  done
}

maybe_start_bridge() {
  # Try to start a systemd *system* service if available.
  local unit="${LOBS_BRIDGE_SYSTEMD_UNIT:-gcal-bridge.service}"
  if command -v systemctl >/dev/null 2>&1; then
    if sudo -n systemctl start "$unit" >/dev/null 2>&1; then
      echo "[lobs-mcp] Started bridge via: sudo systemctl start $unit" >&2
      return 0
    fi
  fi

  # Fallback: directly run the bridge as a specific user.
  local run_as="${LOBS_BRIDGE_RUN_AS:-}"
  if [ -n "$run_as" ]; then
    if sudo -n -u "$run_as" "$ROOT_DIR/bin/start-bridge" >/dev/null 2>&1 & then
      echo "[lobs-mcp] Started bridge via: sudo -u $run_as $ROOT_DIR/bin/start-bridge" >&2
      return 0
    fi
  fi

  return 0
}

maybe_start_bridge

if ! wait_for_http "$LOBS_BRIDGE_HTTP_URL" 5; then
  cat >&2 <<EOF
[lobs-mcp] Bridge HTTP not available: $LOBS_BRIDGE_HTTP_URL

Tried:
  - sudo systemctl start ${LOBS_BRIDGE_SYSTEMD_UNIT:-gcal-bridge.service}
  - sudo -u <user> $ROOT_DIR/bin/start-bridge   (set LOBS_BRIDGE_RUN_AS)

Fix:
  - Ensure the bridge daemon is running and listening on that URL.
EOF
  exit 1
fi

npm run -s build
exec node dist/index.js
