#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

# Load persistent config (no exports needed beforehand)
# shellcheck disable=SC1091
source "$ROOT_DIR/bin/_env.sh"

# Ensure deps are installed (tsc lives in node_modules/.bin)
if [ ! -x "node_modules/.bin/tsc" ]; then
  echo "[lobs-mcp] Installing dependencies..." >&2
  npm install >&2
fi

# Build then run MCP server over stdio.
# (MCP clients spawn this and communicate via stdin/stdout.)

npm run -s build
exec node dist/index.js
