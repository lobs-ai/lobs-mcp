#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

# Load repo/user config
# shellcheck disable=SC1091
source "$ROOT_DIR/bin/_env.sh"

# Ensure deps are installed (tsc lives in node_modules/.bin)
if [ ! -x "node_modules/.bin/tsc" ]; then
  echo "[gcal-bridge] Installing dependencies..." >&2
  npm install >&2
fi

# Avoid rebuilding on every start (especially under systemd).
# Build only if dist is missing or LOBS_FORCE_BUILD=1.
if [ "${LOBS_FORCE_BUILD:-}" = "1" ] || [ ! -f "dist/bridgeHost.js" ]; then
  npm run -s build
fi

exec node dist/bridgeHost.js
