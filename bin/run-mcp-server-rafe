#!/usr/bin/env bash
set -euo pipefail

# Run the MCP server as the current user (rafe), pointing at the local bridge.
# Usage:
#   ./bin/run-mcp-server-rafe
#   ./bin/run-mcp-server-rafe http://127.0.0.1:17381

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

# Load config defaults
# shellcheck disable=SC1091
source "$ROOT_DIR/bin/_env.sh"

if [ "${1:-}" != "" ]; then
  export LOBS_BRIDGE_HTTP_URL="$1"
fi

exec "$ROOT_DIR/bin/start-mcp"
