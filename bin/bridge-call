#!/usr/bin/env bash
set -euo pipefail

# Send one JSONL request to the bridge over a Unix domain socket and print the single-line JSON response.
#
# Usage:
#   bridge-call <method> [params-json]
#
# Examples:
#   bridge-call ping
#   bridge-call gmail.unread '{"max":10}'
#   bridge-call calendar.upcoming '{"hours":48,"tz":"America/New_York"}'

METHOD="${1:-}"
PARAMS_JSON="${2:-}"

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck disable=SC1091
source "$ROOT_DIR/bin/_env.sh"

if [[ -z "$METHOD" || "$METHOD" == "-h" || "$METHOD" == "--help" ]]; then
  cat >&2 <<'EOF'
Usage:
  bridge-call <method> [params-json]

Config (no exports required):
  ~/.config/lobs-mcp/config.env

Environment override (optional):
  LOBS_BRIDGE_SOCKET       Path to UDS
  LOBS_BRIDGE_TIMEOUT_MS   Timeout in ms

Examples:
  bridge-call ping
  bridge-call gmail.unread '{"max":10}'
  bridge-call calendar.upcoming '{"hours":48,"tz":"America/New_York"}'
EOF
  exit 2
fi

if ! command -v socat >/dev/null 2>&1; then
  echo "bridge-call requires 'socat' (for Unix socket I/O)." >&2
  echo "Install it (Ubuntu/WSL): sudo apt-get update && sudo apt-get install -y socat" >&2
  exit 1
fi

# Unique id for request/response correlation
REQ_ID="$(date +%s)-$$-$RANDOM"

# Build request JSON (avoid jq dependency)
if [[ -n "$PARAMS_JSON" ]]; then
  REQ_LINE="{\"id\":\"$REQ_ID\",\"method\":\"$METHOD\",\"params\":$PARAMS_JSON}"
else
  REQ_LINE="{\"id\":\"$REQ_ID\",\"method\":\"$METHOD\"}"
fi

# Send one line, read one line. We rely on the bridge to answer with exactly one JSON line.
# -t: idle timeout seconds
TIMEOUT_S=$(( (LOBS_BRIDGE_TIMEOUT_MS + 999) / 1000 ))

RESP_LINE="$(
  printf '%s\n' "$REQ_LINE" \
    | socat -t "$TIMEOUT_S" - "UNIX-CONNECT:$LOBS_BRIDGE_SOCKET" \
    | head -n 1
)"

if [[ -z "$RESP_LINE" ]]; then
  echo "No response from bridge (socket=$LOBS_BRIDGE_SOCKET, timeout=${LOBS_BRIDGE_TIMEOUT_MS}ms)" >&2
  exit 1
fi

printf '%s\n' "$RESP_LINE"
