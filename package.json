{
  "name": "lobs-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MCP server for Lobs (OpenClaw) to access local services via a UDS bridge (Gmail readonly + Google Calendar RW).",
  "license": "MIT",
  "main": "dist/index.js",
  "bin": {
    "lobs-mcp": "dist/index.js",
    "gcal-bridge": "dist/bridgeHost.js",
    "lobs-google-auth": "dist/googleAuthCli.js"
  },
  "scripts": {
    "build": "npm exec -- tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "npm run build && node --test dist/*.test.js",
    "lint": "eslint .",
    "format": "prettier -w ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "googleapis": "^144.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  }
}
